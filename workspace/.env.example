# OpenClaw Researcher — Environment Variables
# Copy to ~/.openclaw/workspace/.env and fill in your keys

# Anthropic API (required)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Voyage AI embedding API (required for paper embedding)
VOYAGE_API_KEY=pa-xxxxx

# MLflow tracking (optional, defaults to local file store)
# MLFLOW_TRACKING_URI=file:///home/user/.openclaw/workspace/data/mlflow
